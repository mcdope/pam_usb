FROM menci/archlinuxarm:base-devel
ENV TERM=xterm
WORKDIR /usr/local/src/pam_usb

RUN --mount=type=tmpfs,target=/var/cache/pacman/pkg \
    useradd -m builduser && \
    pacman-key --init && \
    pacman --noconfirm -Sy archlinux-keyring && \
    pacman --noconfirm -Syu && \
    pacman --noconfirm -S --needed sudo git pkgconf gcc make patch pam dbus python python-dbus python-lxml python-gobject udisks2 libevdev base-devel pacman-contrib
